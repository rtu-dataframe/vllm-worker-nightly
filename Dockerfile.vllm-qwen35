ARG BASE_IMAGE
FROM ${BASE_IMAGE}

# ---------------------------------------------------------------------------
# Pin vLLM to stable 0.17.0 (Qwen3.5 support: GDN, reasoning parser, FP8)
# ---------------------------------------------------------------------------
ARG VLLM_VERSION=0.17.0
RUN pip install --no-cache-dir \
        "vllm[flashinfer]==${VLLM_VERSION}" \
        --extra-index-url https://download.pytorch.org/whl/cu129

# Debug: verify vLLM version and language_model_only support
RUN python3 -c "import vllm; print(f'vLLM version: {vllm.__version__}'); \
    from vllm.engine.arg_utils import AsyncEngineArgs; \
    fields = AsyncEngineArgs.__dataclass_fields__; \
    print(f'language_model_only field exists: {\"language_model_only\" in fields}'); \
    print(f'Total fields: {len(fields)}')"

# Patch: inject runtime debug to log effective engine args before vLLM starts
RUN python3 -c "\
import pathlib, re; \
ea = pathlib.Path('/usr/local/lib/python3.10/dist-packages/runpod_wrapper/engine_args.py'); \
alt = list(pathlib.Path('/usr/local/lib/python3.10/dist-packages').rglob('engine_args.py')); \
print('engine_args.py locations:', [str(p) for p in alt]); \
"
