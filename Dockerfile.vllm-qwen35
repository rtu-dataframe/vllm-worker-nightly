ARG BASE_IMAGE
FROM ${BASE_IMAGE}

# ---------------------------------------------------------------------------
# Pin vLLM to stable 0.17.0 (Qwen3.5 support: GDN, reasoning parser, FP8)
# ---------------------------------------------------------------------------
ARG VLLM_VERSION=0.17.0
RUN pip install --no-cache-dir \
        "vllm[flashinfer]==${VLLM_VERSION}" \
        --extra-index-url https://download.pytorch.org/whl/cu129

# ---------------------------------------------------------------------------
# Install CUDA compiler (nvcc) — required by FlashInfer to JIT-compile
# GDN (Gated Delta Network) kernels for Qwen3.5 at first startup.
# The base worker-vllm image is runtime-only and does not include nvcc.
# ---------------------------------------------------------------------------
RUN apt-get update && \
    apt-get install -y --no-install-recommends cuda-nvcc-12-9 && \
    rm -rf /var/lib/apt/lists/*
