ARG BASE_IMAGE
FROM ${BASE_IMAGE}

# FlashInfer JIT-compiles the GDN (linear attention) kernels for Qwen3.5 on sm90a (H100).
# Requires: nvcc (CUDA compiler) + ninja (build orchestrator).
# The base worker-vllm image only ships the CUDA runtime — add the compiler + dev headers.
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        cuda-nvcc-12-9 \
        cuda-cudart-dev-12-9 \
        ninja-build \
 && pip install --no-cache-dir ninja \
 && rm -rf /var/lib/apt/lists/*
